{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Aspire.Hosting.Dcp": "Warning"
    }
  },

  "Foundry": {
    "Project": {
      "Endpoint": "https://{FOUNDRY_NAME}.services.ai.azure.com/api/projects/{FOUNDRY_PROJECT_NAME}",
      "Model": "gpt-5-mini",
      "Agents": [
        {
          "Name": "research-agent",
          "Version": "1"
        },
        {
          "Name": "outliner-agent",
          "Version": "1"
        },
        {
          "Name": "writer-agent",
          "Version": "1"
        },
        {
          "Name": "editor-agent",
          "Version": "1"
        }
      ]
    }
  }
}
